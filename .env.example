GEOCATALOG_DB_NAME=geocatalog
GEOCATALOG_DB_USER=geocatalog
GEOCATALOG_DB_PASSWORD=geocatalog_dev
# Host port for GeoCatalog PostGIS. The container still uses 5432 internally.
# This avoids conflict with hotspot-new, which commonly publishes PostGIS on 5432.
GEOCATALOG_DB_HOST_PORT=55432
GEOCATALOG_API_PORT=8010
GEOCATALOG_FRONTEND_PORT=8090
GEOCATALOG_TILER_PORT=8011
GEOCATALOG_SCAN_ROOT=/mnt/geomimo-data
GEOCATALOG_WORKER_INTERVAL_SECONDS=600
GEOCATALOG_FOOTPRINT_BATCH_SIZE=1000
GEOCATALOG_FOOTPRINT_INTERVAL_SECONDS=600
GEOCATALOG_FOOTPRINT_PROGRESS_INTERVAL=100

# ---------------------------------------------------------------------------
# PgSTAC — separate PostgreSQL instance for the standards-grade STAC API.
# Used by the pgstac-db container and the geocatalog stac sync command.
# ---------------------------------------------------------------------------
PGSTAC_DB_NAME=pgstac
PGSTAC_DB_USER=pgstac
PGSTAC_DB_PASSWORD=pgstac_dev
# Host port for PgSTAC PostGIS. Container uses 5432 internally.
PGSTAC_DB_HOST_PORT=55433
# Port exposed by the stac-fastapi-pgstac service.
STAC_API_PORT=8012

# ---------------------------------------------------------------------------
# STAC sync worker settings (read by geocatalog stac sync).
# Set GEOCATALOG_PGSTAC_HOST to the internal Docker service name when running
# the sync worker inside Docker Compose (i.e. pgstac-db).
# ---------------------------------------------------------------------------
GEOCATALOG_PGSTAC_HOST=localhost
GEOCATALOG_PGSTAC_PORT=55433
GEOCATALOG_PGSTAC_NAME=pgstac
GEOCATALOG_PGSTAC_USER=pgstac
GEOCATALOG_PGSTAC_PASSWORD=pgstac_dev
# Public base URL of the nginx/frontend entry point, embedded in STAC asset hrefs.
# Downloads should pass through nginx because large files use X-Accel-Redirect.
# On the server this should be the externally reachable address, for example:
GEOCATALOG_API_BASE_URL=http://localhost:8090
GEOCATALOG_DOWNLOAD_TICKET_SECRET=change-this-in-production
GEOCATALOG_DOWNLOAD_TICKET_TTL_SECONDS=300
GEOCATALOG_ACCESS_SESSION_TIMEOUT_DAYS=3
# Interval between incremental STAC sync passes (seconds). Default 10 minutes.
GEOCATALOG_STAC_SYNC_INTERVAL_SECONDS=600
